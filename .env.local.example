# ============================================
# EMET Platform - Environment Variables
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI Providers (Priority: Groq → Google → OpenAI → Anthropic) ---
# Groq (Llama 3.1 70B - cheapest, used for general conversation)
GROQ_API_KEY=your-groq-api-key

# Google AI (Gemini 2.0 Flash - used for analysis)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# OpenAI (GPT-4o-mini - fallback)
OPENAI_API_KEY=your-openai-api-key

# Anthropic (Claude 3.5 Sonnet - used for coding/complex tasks)
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Solana ---
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-min-32-chars

# --- Social APIs (Phase 2) ---
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# INSTAGRAM_ACCESS_TOKEN=
